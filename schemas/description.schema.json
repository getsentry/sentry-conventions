{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$ref": "#/definitions/SpanDescription",
  "definitions": {
    "SpanDescription": {
      "title": "SpanDescription",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "brief": {
          "type": "string"
        },
        "operations": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/definitions/SpanOperation"
          }
        }
      },
      "required": ["brief", "operations"]
    },
    "SpanOperation": {
      "title": "SpanOperation",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string"
        },
        "brief": {
          "type": "string"
        },
        "ops": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "templates": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "examples": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "required": ["brief", "ops", "templates"]
    }
  }
}

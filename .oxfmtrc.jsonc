{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "printWidth": 120,
  "tabWidth": 2,
  "useTabs": false,
  "semi": true,
  "singleQuote": true,
  "jsxSingleQuote": false,
  "quoteProps": "as-needed",
  "trailingComma": "all",
  "bracketSpacing": true,
  "bracketSameLine": false,
  "arrowParens": "always",
  "endOfLine": "lf",
  "sortImports": false,
  "sortPackageJson": false,
  "ignorePatterns": [
    "**/dist/**",
    "**/rust/**",
    "**/python/**",
    "**/.claude/**",
    "**/.astro/**",
    "javascript/sentry-conventions/package.json",
  ],
}
